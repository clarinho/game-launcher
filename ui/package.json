{
  "name": "campfire-ui",
  "version": "1.0.0",
  "description": "Campfire desktop launcher UI",
  "author": "Campfire",
  "license": "MIT",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dev": "nodemon --watch main.js --watch preload.js --watch renderer.js --watch index.html --watch style.css --exec \"electron .\"",
    "dist:win": "electron-builder --win nsis"
  },
  "build": {
    "appId": "com.campfire.launcher",
    "productName": "Campfire",
    "directories": {
      "output": "../dist/ui"
    },
    "files": [
      "main.js",
      "preload.js",
      "renderer.js",
      "index.html",
      "style.css",
      "package.json"
    ],
    "artifactName": "Campfire-Setup-${version}.${ext}",
    "extraResources": [
      {
        "from": "../build/campfire.exe",
        "to": "campfire/campfire.exe"
      }
    ],
    "win": {
      "icon": "assets/campfire.ico",
      "target": [
        "nsis"
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": false,
      "createDesktopShortcut": true,
      "shortcutName": "Campfire",
      "installerIcon": "assets/campfire.ico",
      "uninstallerIcon": "assets/campfire.ico",
      "installerHeaderIcon": "assets/campfire.ico"
    }
  },
  "devDependencies": {
    "electron": "^40.6.1",
    "electron-builder": "^26.0.12",
    "nodemon": "^3.1.10"
  }
}
